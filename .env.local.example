NEXT_PUBLIC_SUPABASE_URL=https://rzmyyyyoqarmzvljruii.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service-role (servidor): gestión de usuarios, permisos y correo de soporte.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# SMTP para el formulario de soporte de /ayuda. Si falta alguna de estas
# (incluyendo SOPORTE_EMAIL_TO), el envío queda deshabilitado y el formulario
# avisa. SMTP_FROM es opcional (por defecto usa SMTP_USER, debe ser una casilla
# autorizada por el proveedor SMTP, no el correo del usuario); SMTP_SECURE=true
# para el puerto 465.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_SECURE=false

# Destino fijo de las solicitudes de soporte (el correo/equipo que da soporte
# del producto, NO el titular del cliente).
SOPORTE_EMAIL_TO=
